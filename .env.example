VITE_SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_PUBLIC_ANON_KEY

# Whoop OAuth (server-side)
WHOOP_OAUTH_CLIENT_ID=your_whoop_client_id
WHOOP_OAUTH_CLIENT_SECRET=your_whoop_client_secret
# Optional; defaults to https://<your-domain>/api/oauth-whoop?action=callback
WHOOP_OAUTH_REDIRECT_URI=
# Optional; space-separated
WHOOP_OAUTH_SCOPES=offline read:profile read:recovery read:sleep read:cycles read:workout

# Outlook/Microsoft Graph OAuth (server-side)
OUTLOOK_OAUTH_CLIENT_ID=your_outlook_client_id
OUTLOOK_OAUTH_CLIENT_SECRET=your_outlook_client_secret
# Optional; defaults to https://<your-domain>/api/oauth-outlook?action=callback
OUTLOOK_OAUTH_REDIRECT_URI=
# Optional; default tenant is "common"
OUTLOOK_OAUTH_TENANT_ID=common
# Optional; space-separated
OUTLOOK_OAUTH_SCOPES=openid profile offline_access https://graph.microsoft.com/Calendars.ReadBasic
